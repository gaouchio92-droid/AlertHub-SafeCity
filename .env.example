APP_NAME="AlertHub Safe City"
APP_ENV=development
SECRET_KEY=replace-with-a-secure-random-secret-key

POSTGRES_HOST=postgres
POSTGRES_DB=alerthub
POSTGRES_USER=alerthub
POSTGRES_PASSWORD=replace-with-a-secure-database-password
DATABASE_URL=postgresql+psycopg://alerthub:replace-with-a-secure-database-password@postgres:5432/alerthub

EVENT_SOURCE=discord
CONNECTOR_IMPORTS=
ENABLE_DISCORD=true
ENABLE_ZABBIX_API=false
ENABLE_ZABBIX_DB=false

DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

ZABBIX_API_URL=
ZABBIX_USERNAME=
ZABBIX_PASSWORD=

ZABBIX_DB_HOST=
ZABBIX_DB_PORT=5432
ZABBIX_DB_NAME=
ZABBIX_DB_USER=
ZABBIX_DB_PASSWORD=

JWT_SECRET=replace-with-a-secure-random-jwt-secret
JWT_EXPIRE_MINUTES=60

SYNC_INTERVAL_SECONDS=300
POSTGRES_BACKUP_INTERVAL_SECONDS=86400
POSTGRES_BACKUP_RETENTION_DAYS=14
HEALTHCHECK_INTERVAL_SECONDS=60
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
