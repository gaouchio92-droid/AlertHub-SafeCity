APP_NAME="AlertHub Safe City"
APP_ENV=development
SECRET_KEY=replace-with-a-secure-random-secret-key

POSTGRES_HOST=postgres
POSTGRES_DB=alerthub
POSTGRES_USER=alerthub
POSTGRES_PASSWORD=replace-with-a-secure-database-password
DATABASE_URL=postgresql+psycopg://alerthub:replace-with-a-secure-database-password@postgres:5432/alerthub

EVENT_SOURCE=discord
CONNECTOR_IMPORTS=
ENABLE_DISCORD=true
ENABLE_ZABBIX_API=false
ENABLE_ZABBIX_DB=false

DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

ZABBIX_API_URL=
ZABBIX_USERNAME=
ZABBIX_PASSWORD=

ZABBIX_DB_HOST=
ZABBIX_DB_PORT=5432
ZABBIX_DB_NAME=
ZABBIX_DB_USER=
ZABBIX_DB_PASSWORD=

JWT_SECRET=replace-with-a-secure-random-jwt-secret
JWT_EXPIRE_MINUTES=60

AUTH_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@alerthub.local
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-secure-admin-password

SYNC_INTERVAL_SECONDS=300
ENABLE_SCHEDULED_REPORT_DELIVERY=true
WEEKLY_REPORT_INTERVAL_DAYS=7
MONTHLY_REPORT_INTERVAL_DAYS=28
DEFAULT_ESCALATION_OWNER="NOC Team"
ESCALATION_OWNER_RULES="disaster:Incident Manager;high:NOC Lead;average:NOC Operator;warning:NOC Operator;information:Monitoring Team"
POSTGRES_BACKUP_INTERVAL_SECONDS=86400
POSTGRES_BACKUP_RETENTION_DAYS=14
HEALTHCHECK_INTERVAL_SECONDS=60
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
